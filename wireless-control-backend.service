[Unit]
Description=Wireless Control Backend (Gunicorn)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/wireless-control/backend
Environment="PATH=/opt/wireless-control/backend/venv/bin"
ExecStart=/opt/wireless-control/backend/venv/bin/gunicorn -w 4 -b 127.0.0.1:5000 app:app --timeout 60 --access-logfile /opt/wireless-control/logs/gunicorn-access.log --error-logfile /opt/wireless-control/logs/gunicorn-error.log
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
