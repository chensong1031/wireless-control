plugins {
    id 'com.android.application'
    id 'org.jetbrains.kotlin.android'
}

android {
    namespace 'com.wireless.control.device'
    compileSdk 34

    defaultConfig {
        applicationId 'com.wireless.control.device'
        minSdk 29
        targetSdk 34
        versionCode 1
        versionName '1.0.0'
    }

    buildTypes {
        debug {
            minifyEnabled false
        }
        release {
            minifyEnabled false
        }
    }

    compileOptions {
        sourceCompatibility JavaVersion.VERSION_1_8
        targetCompatibility JavaVersion.VERSION_1_8
    }

    kotlinOptions {
        jvmTarget = '1.8'
    }
}

// 任务：复制APK到指定目录
task copyApkToWorkspace(dependsOn: ['assembleDebug']) {
    doLast {
        def projectDir = project.rootDir.parent.parent.parent
        def outputDir = file(projectDir, "workspace/projects/workspace/projects/apk")
        outputDir.mkdirs()
        
        def apkFile = file("${projectDir}/device-module/app/build/outputs/apk/debug/app-debug.apk")
        if (apkFile.exists()) {
            copy {
                from apkFile
                into outputDir
                rename "worktone-latest.apk"
            }
            println("✓ APK copied to: ${outputDir}/worktone-latest.apk")
        } else {
            println("⚠ APK file not found: $apkFile")
        }
    }
}

dependencies {
    implementation 'androidx.core:core-ktx:1.12.0'
    implementation 'androidx.appcompat:appcompat:1.6.1'
    implementation 'com.google.android.material:material:1.11.0'
    implementation 'androidx.constraintlayout:constraintlayout:2.1.4'

    // HTTP服务器
    implementation 'org.nanohttpd:nanohttpd:2.3.1'
    implementation 'org.nanohttpd:nanohttpd-webserver:2.3.1'
    implementation 'org.nanohttpd:nanohttpd-websocket:2.3.1'

    // JSON处理
    implementation 'com.google.code.gson:gson:2.10.1'
    implementation 'org.json:json:20231013'

    // 网络请求
    implementation 'com.squareup.okhttp3:okhttp:4.12.0'

    // 协程支持
    implementation 'org.jetbrains.kotlinx:kotlinx-coroutines-android:1.7.3'
    implementation 'androidx.lifecycle:lifecycle-runtime-ktx:2.6.2'
    implementation 'androidx.lifecycle:lifecycle-service:2.6.2'
    implementation 'androidx.activity:activity-ktx:1.7.2'

    // 二维码扫描
    implementation 'androidx.camera:camera-core:1.3.1'
    implementation 'androidx.camera:camera-camera2:1.3.1'
    implementation 'androidx.camera:camera-lifecycle:1.3.1'
    implementation 'androidx.camera:camera-view:1.3.1'
    implementation 'com.google.zxing:core:3.5.2'

    // Xposed API - 核心依赖，必须保留
    compileOnly 'de.robv.android.xposed:api:82'
}
